<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
        <!-- Local SF SDK packages — matches your installed runtime version exactly -->
        <add key="ServiceFabricLocal" value="C:\Program Files\Microsoft SDKs\Service Fabric\packages" />
    </packageSources>

    <packageSourceMapping>
        <packageSource key="ServiceFabricLocal">
            <!-- Route SF packages to the local SDK feed first.
           This ensures your NuGet version matches the installed runtime exactly,
           which prevents subtle version mismatch issues at runtime. -->
            <package pattern="Microsoft.ServiceFabric*" />
        </packageSource>
        <packageSource key="nuget.org">
            <package pattern="System.*" />
            <package pattern="System.ClientModel" />
            <package pattern="Swashbuckle.AspNetCore.Swagger" />
            <package pattern="Swashbuckle.AspNetCore" />
        </packageSource>
    </packageSourceMapping>
</configuration>